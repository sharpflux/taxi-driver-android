<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme for dark mode -->
    <style name="Theme.TaxiApp" parent="Theme.MaterialComponents.DayNight.DarkActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorPrimaryVariant">@color/colorPrimary</item>
        <item name="colorOnPrimary">@color/black</item>
        <item name="colorAccent">@color/colorPrimary</item>
        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/teal_200</item>
        <item name="colorSecondaryVariant">@color/teal_200</item>
        <item name="colorOnSecondary">@color/black</item>

        <!-- Status bar color. -->
        <!--        <item name="android:statusBarColor">?attr/colorPrimaryVariant</item>-->
        <item name="android:statusBarColor">@color/black</item>
        <item name="android:windowLightStatusBar">false</item>


        <!-- Custom theme attributes for dark mode -->
        <item name="background_color">@color/background_primary</item>
        <item name="surface_background_color">@color/background_secondary</item>
        <item name="text_primary_color">@color/text_primary</item>
        <item name="text_secondary_color">@color/text_secondary</item>
        <item name="text_hint_color">@color/text_hint</item>
        <item name="input_bg_color">@color/input_background</item>
        <item name="border_color_attr">@color/border_color</item>
        <item name="icon_tint_color">@color/icon_tint</item>
        <item name="link_text_color">@color/link_color</item>
    </style>

    <!-- Splash screen theme -->
    <style name="Theme.TaxiApp.Splash" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="windowSplashScreenBackground">@color/colorPrimary</item>
        <item name="windowSplashScreenAnimatedIcon">@mipmap/ic_launcher</item>
        <item name="postSplashScreenTheme">@style/Theme.TaxiApp.NoActionBar</item>
    </style>

    <style name="Theme.TaxiApp.NoActionBar" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>

        <!-- Custom theme attributes for dark mode -->
        <item name="background_color">@color/background_primary</item>
        <item name="surface_background_color">@color/background_secondary</item>
        <item name="text_primary_color">@color/text_primary</item>
        <item name="text_secondary_color">@color/text_secondary</item>
        <item name="text_hint_color">@color/text_hint</item>
        <item name="input_bg_color">@color/input_background</item>
        <item name="border_color_attr">@color/border_color</item>
        <item name="icon_tint_color">@color/icon_tint</item>
        <item name="link_text_color">@color/link_color</item>
    </style>

    <style name="RoundedImageStyle">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">16dp</item>
    </style>

    <style name="CustomAlertDialog" parent="ThemeOverlay.MaterialComponents.MaterialAlertDialog">
        <item name="android:background">@drawable/dialog_background</item>
        <item name="android:textColorPrimary">?attr/text_primary_color</item>
        <item name="android:textColorSecondary">?attr/text_secondary_color</item>
        <item name="buttonBarPositiveButtonStyle">@style/DialogButtonStyle</item>
        <item name="buttonBarNegativeButtonStyle">@style/DialogButtonStyle</item>
    </style>

    <style name="WhiteAlertDialog" parent="ThemeOverlay.MaterialComponents.MaterialAlertDialog">
        <item name="android:background">@drawable/dialog_background</item>
        <item name="android:textColorPrimary">?attr/text_primary_color</item>
    </style>

    <style name="DialogButtonStyle" parent="Widget.MaterialComponents.Button.TextButton">
        <item name="android:textColor">?attr/link_text_color</item>
        <!--        <item name="android:textColor">#FFC107</item>-->
    </style>

</resources>