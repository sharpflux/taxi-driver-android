<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="?attr/background_color"
    android:fitsSystemWindows="true">

    <!-- Header -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp"
        android:background="?attr/surface_background_color"
        android:elevation="4dp">

        <ImageView
            android:id="@+id/ivBackButton"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true"
            android:src="@drawable/ic_arrow_back"
            android:padding="8dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            app:tint="?attr/icon_tint_color"
            android:contentDescription="@string/back" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/driver_registration"
            android:textStyle="bold"
            android:textSize="24sp"
            android:textColor="?attr/text_primary_color"
            android:layout_centerInParent="true" />
    </RelativeLayout>

    <!-- ViewFlipper: each child = one step -->
    <ViewFlipper
        android:id="@+id/viewFlipper"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <!-- STEP 1: Personal Information -->
        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true"
            android:isScrollContainer="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp"
                android:paddingBottom="600dp"
                android:clipToPadding="false">

                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="24dp"
                    android:elevation="4dp"
                    app:cardCornerRadius="12dp"
                    app:cardBackgroundColor="?attr/surface_background_color">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/personal_information"
                            android:textStyle="bold"
                            android:textSize="18sp"
                            android:textColor="?attr/text_primary_color"
                            android:layout_marginBottom="20dp" />

                        <com.google.android.material.textfield.TextInputLayout
                            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="16dp"
                            app:boxBackgroundMode="outline"
                            app:boxBackgroundColor="?attr/input_bg_color"
                            app:boxStrokeColor="?attr/border_color_attr"
                            app:hintTextColor="?attr/text_hint_color"
                            app:boxCornerRadiusTopStart="12dp"
                            app:boxCornerRadiusTopEnd="12dp"
                            app:boxCornerRadiusBottomStart="12dp"
                            app:boxCornerRadiusBottomEnd="12dp">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etFirstName"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:hint="@string/first_name_required"
                                android:textColor="?attr/text_primary_color"
                                android:textColorHint="?attr/text_hint_color"
                                android:inputType="textCapWords" />
                        </com.google.android.material.textfield.TextInputLayout>

                        <com.google.android.material.textfield.TextInputLayout
                            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="16dp"
                            app:boxBackgroundMode="outline"
                            app:boxBackgroundColor="?attr/input_bg_color"
                            app:boxStrokeColor="?attr/border_color_attr"
                            app:hintTextColor="?attr/text_hint_color"
                            app:boxCornerRadiusTopStart="12dp"
                            app:boxCornerRadiusTopEnd="12dp"
                            app:boxCornerRadiusBottomStart="12dp"
                            app:boxCornerRadiusBottomEnd="12dp">
                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etMiddleName"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:hint="@string/middle_name_optional"
                                android:textColor="?attr/text_primary_color"
                                android:textColorHint="?attr/text_hint_color"
                                android:inputType="textCapWords" />
                        </com.google.android.material.textfield.TextInputLayout>

                        <com.google.android.material.textfield.TextInputLayout
                            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="16dp"
                            app:boxBackgroundMode="outline"
                            app:boxBackgroundColor="?attr/input_bg_color"
                            app:boxStrokeColor="?attr/border_color_attr"
                            app:hintTextColor="?attr/text_hint_color"
                            app:boxCornerRadiusTopStart="12dp"
                            app:boxCornerRadiusTopEnd="12dp"
                            app:boxCornerRadiusBottomStart="12dp"
                            app:boxCornerRadiusBottomEnd="12dp">
                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etLastName"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:hint="@string/last_name_required"
                                android:textColor="?attr/text_primary_color"
                                android:textColorHint="?attr/text_hint_color"
                                android:inputType="textCapWords" />
                        </com.google.android.material.textfield.TextInputLayout>

                        <com.google.android.material.textfield.TextInputLayout
                            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="16dp"
                            app:boxBackgroundMode="outline"
                            app:boxBackgroundColor="?attr/input_bg_color"
                            app:boxStrokeColor="?attr/border_color_attr"
                            app:hintTextColor="?attr/text_hint_color"
                            app:boxCornerRadiusTopStart="12dp"
                            app:boxCornerRadiusTopEnd="12dp"
                            app:boxCornerRadiusBottomStart="12dp"
                            app:boxCornerRadiusBottomEnd="12dp">
                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etEmailId"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:hint="@string/email_required"
                                android:textColor="?attr/text_primary_color"
                                android:textColorHint="?attr/text_hint_color"
                                android:inputType="textEmailAddress" />
                        </com.google.android.material.textfield.TextInputLayout>

                        <com.google.android.material.textfield.TextInputLayout
                            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="16dp"
                            app:boxBackgroundMode="outline"
                            app:boxBackgroundColor="?attr/input_bg_color"
                            app:boxStrokeColor="?attr/border_color_attr"
                            app:hintTextColor="?attr/text_hint_color"
                            app:boxCornerRadiusTopStart="12dp"
                            app:boxCornerRadiusTopEnd="12dp"
                            app:boxCornerRadiusBottomStart="12dp"
                            app:boxCornerRadiusBottomEnd="12dp">
                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etPhoneNumber"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:hint="@string/phone_required"
                                android:textColor="?attr/text_primary_color"
                                android:textColorHint="?attr/text_hint_color"
                                android:inputType="phone"
                                android:maxLength="10" />
                        </com.google.android.material.textfield.TextInputLayout>

                        <com.google.android.material.textfield.TextInputLayout
                            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="16dp"
                            app:boxBackgroundMode="outline"
                            app:boxBackgroundColor="?attr/input_bg_color"
                            app:boxStrokeColor="?attr/border_color_attr"
                            app:hintTextColor="?attr/text_hint_color"
                            app:boxCornerRadiusTopStart="12dp"
                            app:boxCornerRadiusTopEnd="12dp"
                            app:boxCornerRadiusBottomStart="12dp"
                            app:boxCornerRadiusBottomEnd="12dp">
                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etAadhar"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:hint="@string/aadhar_required"
                                android:textColor="?attr/text_primary_color"
                                android:textColorHint="?attr/text_hint_color"
                                android:inputType="number"
                                android:maxLength="12" />
                        </com.google.android.material.textfield.TextInputLayout>

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/gender_required"
                            android:textSize="14sp"
                            android:textColor="?attr/text_secondary_color"
                            android:layout_marginBottom="8dp" />

                        <RadioGroup
                            android:id="@+id/rgGender"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginBottom="16dp">

                            <RadioButton
                                android:id="@+id/rbMale"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="@string/male"
                                android:textColor="?attr/text_primary_color"
                                android:buttonTint="@color/radio_button_tint" />

                            <RadioButton
                                android:id="@+id/rbFemale"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="@string/female"
                                android:textColor="?attr/text_primary_color"
                                android:buttonTint="@color/radio_button_tint" />
                        </RadioGroup>

                        <com.google.android.material.textfield.TextInputLayout
                            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="16dp"
                            app:boxBackgroundMode="outline"
                            app:boxBackgroundColor="?attr/input_bg_color"
                            app:boxStrokeColor="?attr/border_color_attr"
                            app:hintTextColor="?attr/text_hint_color"
                            app:boxCornerRadiusTopStart="12dp"
                            app:boxCornerRadiusTopEnd="12dp"
                            app:boxCornerRadiusBottomStart="12dp"
                            app:boxCornerRadiusBottomEnd="12dp"
                            app:passwordToggleEnabled="true"
                            app:passwordToggleTint="?attr/icon_tint_color">
                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etPassword"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:hint="@string/password_required"
                                android:textColor="?attr/text_primary_color"
                                android:textColorHint="?attr/text_hint_color"
                                android:inputType="textPassword" />
                        </com.google.android.material.textfield.TextInputLayout>

                        <Button
                            android:id="@+id/btnNext1"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:backgroundTint="?attr/colorPrimary"
                            android:textColor="@color/black"
                            android:text="@string/next_arrow"
                            android:background="@color/link_color"
                            app:cornerRadius="12dp" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>
            </LinearLayout>
        </androidx.core.widget.NestedScrollView>

        <!-- STEP 2: Address Information -->
        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:elevation="4dp"
                    app:cardCornerRadius="12dp"
                    app:cardBackgroundColor="?attr/surface_background_color">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/address_information"
                            android:textStyle="bold"
                            android:textSize="18sp"
                            android:textColor="?attr/text_primary_color"
                            android:layout_marginBottom="20dp" />

                        <com.google.android.material.textfield.TextInputLayout
                            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="16dp"
                            app:boxBackgroundMode="outline"
                            app:boxBackgroundColor="?attr/input_bg_color"
                            app:boxStrokeColor="?attr/border_color_attr"
                            app:hintTextColor="?attr/text_hint_color"
                            app:boxCornerRadiusTopStart="12dp"
                            app:boxCornerRadiusTopEnd="12dp"
                            app:boxCornerRadiusBottomStart="12dp"
                            app:boxCornerRadiusBottomEnd="12dp">
                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etAddress"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:hint="@string/street_address_required"
                                android:textColor="?attr/text_primary_color"
                                android:textColorHint="?attr/text_hint_color"
                                android:inputType="textMultiLine"
                                android:minLines="2" />
                        </com.google.android.material.textfield.TextInputLayout>

                        <com.google.android.material.textfield.TextInputLayout
                            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="16dp"
                            app:boxBackgroundMode="outline"
                            app:boxBackgroundColor="?attr/input_bg_color"
                            app:boxStrokeColor="?attr/border_color_attr"
                            app:hintTextColor="?attr/text_hint_color"
                            app:boxCornerRadiusTopStart="12dp"
                            app:boxCornerRadiusTopEnd="12dp"
                            app:boxCornerRadiusBottomStart="12dp"
                            app:boxCornerRadiusBottomEnd="12dp">
                            <AutoCompleteTextView
                                android:id="@+id/actvState"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:hint="@string/select_state_required"
                                android:textColor="?attr/text_primary_color"
                                android:textColorHint="?attr/text_hint_color"
                                android:inputType="text"
                                android:focusable="true"
                                android:clickable="true"
                                android:completionThreshold="1" />
                        </com.google.android.material.textfield.TextInputLayout>

                        <com.google.android.material.textfield.TextInputLayout
                            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="16dp"
                            app:boxBackgroundMode="outline"
                            app:boxBackgroundColor="?attr/input_bg_color"
                            app:boxStrokeColor="?attr/border_color_attr"
                            app:hintTextColor="?attr/text_hint_color"
                            app:boxCornerRadiusTopStart="12dp"
                            app:boxCornerRadiusTopEnd="12dp"
                            app:boxCornerRadiusBottomStart="12dp"
                            app:boxCornerRadiusBottomEnd="12dp">
                            <AutoCompleteTextView
                                android:id="@+id/actvCity"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:hint="@string/select_city_required"
                                android:textColor="?attr/text_primary_color"
                                android:textColorHint="?attr/text_hint_color"
                                android:inputType="text"
                                android:focusable="true"
                                android:clickable="true"
                                android:completionThreshold="1" />
                        </com.google.android.material.textfield.TextInputLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                            <Button
                                android:id="@+id/btnBack2"
                                android:layout_width="0dp"
                                android:layout_weight="1"
                                android:layout_height="wrap_content"
                                android:layout_marginEnd="8dp"
                                android:backgroundTint="?attr/colorPrimary"
                                android:textColor="@color/black"
                                android:text="@string/back_arrow"
                                app:cornerRadius="12dp" />

                            <Button
                                android:id="@+id/btnNext2"
                                android:layout_width="0dp"
                                android:layout_weight="1"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="8dp"
                                android:backgroundTint="?attr/colorPrimary"
                                android:textColor="@color/black"
                                android:text="@string/next_arrow"
                                app:cornerRadius="12dp" />
                        </LinearLayout>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>
            </LinearLayout>
        </androidx.core.widget.NestedScrollView>

        <!-- STEP 3: Vehicle Information & Document Validity -->
        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:elevation="4dp"
                    app:cardCornerRadius="12dp"
                    app:cardBackgroundColor="?attr/surface_background_color">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/vehicle_information"
                            android:textStyle="bold"
                            android:textSize="18sp"
                            android:textColor="?attr/text_primary_color"
                            android:layout_marginBottom="20dp" />

                        <com.google.android.material.textfield.TextInputLayout
                            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="16dp"
                            app:boxBackgroundMode="outline"
                            app:boxBackgroundColor="?attr/input_bg_color"
                            app:boxStrokeColor="?attr/border_color_attr"
                            app:hintTextColor="?attr/text_hint_color"
                            app:boxCornerRadiusTopStart="12dp"
                            app:boxCornerRadiusTopEnd="12dp"
                            app:boxCornerRadiusBottomStart="12dp"
                            app:boxCornerRadiusBottomEnd="12dp">
                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etVehicleNumber"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:hint="@string/vehicle_number_required"
                                android:textColor="?attr/text_primary_color"
                                android:textColorHint="?attr/text_hint_color"
                                android:inputType="textCapCharacters" />
                        </com.google.android.material.textfield.TextInputLayout>

                        <com.google.android.material.textfield.TextInputLayout
                            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="16dp"
                            app:boxBackgroundMode="outline"
                            app:boxBackgroundColor="?attr/input_bg_color"
                            app:boxStrokeColor="?attr/border_color_attr"
                            app:hintTextColor="?attr/text_hint_color"
                            app:boxCornerRadiusTopStart="12dp"
                            app:boxCornerRadiusTopEnd="12dp"
                            app:boxCornerRadiusBottomStart="12dp"
                            app:boxCornerRadiusBottomEnd="12dp">
                            <AutoCompleteTextView
                                android:id="@+id/actvVehicleType"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:hint="@string/select_vehicle_type_required"
                                android:textColor="?attr/text_primary_color"
                                android:textColorHint="?attr/text_hint_color"
                                android:inputType="text"
                                android:focusable="true"
                                android:clickable="true"
                                android:completionThreshold="1" />
                        </com.google.android.material.textfield.TextInputLayout>

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/document_validity"
                            android:textStyle="bold"
                            android:textSize="18sp"
                            android:textColor="?attr/text_primary_color"
                            android:layout_marginBottom="20dp" />

                        <com.google.android.material.textfield.TextInputLayout
                            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="16dp"
                            app:boxBackgroundMode="outline"
                            app:boxBackgroundColor="?attr/input_bg_color"
                            app:boxStrokeColor="?attr/border_color_attr"
                            app:hintTextColor="?attr/text_hint_color"
                            app:boxCornerRadiusTopStart="12dp"
                            app:boxCornerRadiusTopEnd="12dp"
                            app:boxCornerRadiusBottomStart="12dp"
                            app:boxCornerRadiusBottomEnd="12dp"
                            app:startIconDrawable="@android:drawable/ic_menu_my_calendar"
                            app:startIconTint="?attr/icon_tint_color">
                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etDlValidTo"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:hint="@string/dl_valid_to_required"
                                android:textColor="?attr/text_primary_color"
                                android:textColorHint="?attr/text_hint_color"
                                android:focusable="false"
                                android:clickable="true"
                                android:inputType="none" />
                        </com.google.android.material.textfield.TextInputLayout>

                        <com.google.android.material.textfield.TextInputLayout
                            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="16dp"
                            app:boxBackgroundMode="outline"
                            app:boxBackgroundColor="?attr/input_bg_color"
                            app:boxStrokeColor="?attr/border_color_attr"
                            app:hintTextColor="?attr/text_hint_color"
                            app:boxCornerRadiusTopStart="12dp"
                            app:boxCornerRadiusTopEnd="12dp"
                            app:boxCornerRadiusBottomStart="12dp"
                            app:boxCornerRadiusBottomEnd="12dp"
                            app:startIconDrawable="@android:drawable/ic_menu_my_calendar"
                            app:startIconTint="?attr/icon_tint_color">
                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etInsuranceValidTo"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:hint="@string/insurance_valid_to_required"
                                android:textColor="?attr/text_primary_color"
                                android:textColorHint="?attr/text_hint_color"
                                android:focusable="false"
                                android:clickable="true"
                                android:inputType="none" />
                        </com.google.android.material.textfield.TextInputLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                            <Button
                                android:id="@+id/btnBack3"
                                android:layout_width="0dp"
                                android:layout_weight="1"
                                android:layout_height="wrap_content"
                                android:layout_marginEnd="8dp"
                                android:backgroundTint="?attr/colorPrimary"
                                android:textColor="@color/black"
                                android:text="@string/back_arrow"
                                app:cornerRadius="12dp" />

                            <Button
                                android:id="@+id/btnNext3"
                                android:layout_width="0dp"
                                android:layout_weight="1"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="8dp"
                                android:backgroundTint="?attr/colorPrimary"
                                android:textColor="@color/black"
                                android:text="@string/next_arrow"
                                app:cornerRadius="12dp" />
                        </LinearLayout>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>
            </LinearLayout>
        </ScrollView>

        <!-- STEP 4: Upload Documents -->
        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:elevation="4dp"
                    app:cardCornerRadius="12dp"
                    app:cardBackgroundColor="?attr/surface_background_color">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/upload_documents"
                            android:textStyle="bold"
                            android:textSize="20sp"
                            android:textColor="?attr/text_primary_color"
                            android:layout_marginBottom="8dp" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/upload_documents_subtitle"
                            android:textSize="14sp"
                            android:textColor="?attr/text_secondary_color"
                            android:layout_marginBottom="24dp" />

                        <!-- Dynamic Documents Container -->
                        <LinearLayout
                            android:id="@+id/documentsContainer"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:layout_marginBottom="24dp" />

                        <!-- Language Selection Section -->
                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/language_preferences"
                            android:textStyle="bold"
                            android:textSize="18sp"
                            android:textColor="?attr/text_primary_color"
                            android:layout_marginBottom="16dp" />

                        <com.google.android.material.textfield.TextInputLayout
                            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="16dp"
                            app:boxBackgroundMode="outline"
                            app:boxBackgroundColor="?attr/input_bg_color"
                            app:boxStrokeColor="?attr/colorPrimary"
                            app:hintTextColor="?attr/text_hint_color"
                            app:boxCornerRadiusTopStart="12dp"
                            app:boxCornerRadiusTopEnd="12dp"
                            app:boxCornerRadiusBottomStart="12dp"
                            app:boxCornerRadiusBottomEnd="12dp">

                            <AutoCompleteTextView
                                android:id="@+id/actvLanguage"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:hint="@string/select_language_required"
                                android:textColor="?attr/text_primary_color"
                                android:textColorHint="?attr/text_hint_color"
                                android:inputType="text"
                                android:focusable="true"
                                android:clickable="true"
                                android:completionThreshold="1" />
                        </com.google.android.material.textfield.TextInputLayout>

                        <!-- Language Checkboxes -->
                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="16dp"
                            app:cardCornerRadius="8dp"
                            app:cardElevation="0dp"
                            app:strokeWidth="1dp"
                            app:strokeColor="?attr/border_color_attr"
                            app:cardBackgroundColor="?attr/surface_background_color">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="vertical"
                                android:padding="16dp">

                                <CheckBox
                                    android:id="@+id/etSpeak"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/can_speak_english"
                                    android:textColor="?attr/text_primary_color"
                                    android:textSize="14sp"
                                    android:layout_marginBottom="8dp"
                                    android:buttonTint="@color/checkbox_tint"  />

                                <CheckBox
                                    android:id="@+id/etUnderstand"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="@string/can_understand_english"
                                    android:textColor="?attr/text_primary_color"
                                    android:textSize="14sp"
                                    android:buttonTint="@color/checkbox_tint"  />
                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>

                        <!-- Terms and Conditions -->
                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/cvTermsConditions"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="16dp"
                            app:cardCornerRadius="8dp"
                            app:cardElevation="2dp"
                            app:strokeWidth="1dp"
                            app:strokeColor="?attr/colorPrimary"
                            app:cardBackgroundColor="?attr/surface_background_color">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:padding="16dp"
                                android:gravity="center_vertical">

                                <ImageView
                                    android:layout_width="24dp"
                                    android:layout_height="24dp"
                                    android:src="@drawable/ic_verification"
                                    app:tint="?attr/colorPrimary"
                                    android:layout_marginEnd="12dp" />

                                <LinearLayout
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:orientation="vertical">

                                    <TextView
                                        android:id="@+id/tvTermsStatus"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="@string/view_terms_conditions"
                                        android:textColor="?attr/text_primary_color"
                                        android:textSize="14sp"
                                        android:textStyle="bold" />

                                    <TextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:text="Click to read and accept"
                                        android:textColor="?attr/text_secondary_color"
                                        android:textSize="12sp"
                                        android:layout_marginTop="4dp" />
                                </LinearLayout>

                                <ImageView
                                    android:id="@+id/ivTermsCheck"
                                    android:layout_width="24dp"
                                    android:layout_height="24dp"
                                    android:src="@android:drawable/checkbox_off_background"
                                    app:tint="?attr/text_secondary_color"
                                    android:visibility="visible" />
                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>


                        <!-- Navigation Buttons -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginBottom="16dp">

                            <Button
                                android:id="@+id/btnBack4"
                                android:layout_width="0dp"
                                android:layout_weight="1"
                                android:layout_height="56dp"
                                android:layout_marginEnd="8dp"
                                android:backgroundTint="?attr/text_secondary_color"
                                android:text="@string/back_arrow"
                                android:textSize="16sp"
                                app:cornerRadius="12dp" />

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnRegister"
                                android:layout_width="0dp"
                                android:layout_weight="2"
                                android:layout_height="56dp"
                                android:layout_marginStart="8dp"
                                android:text="@string/register_as_driver"
                                android:textSize="16sp"
                                android:textStyle="bold"
                                android:textColor="@color/white"
                                app:cornerRadius="12dp"
                                app:backgroundTint="@color/colorAccent"
                                app:icon="@drawable/ic_verification"
                                app:iconGravity="textEnd"
                                app:iconTint="@color/white" />
                        </LinearLayout>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>
            </LinearLayout>
        </ScrollView>

    </ViewFlipper>
</LinearLayout>