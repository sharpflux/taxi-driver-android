<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"

    android:background="?attr/background_color">


    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp"
        android:background="#ffffff"
        android:elevation="4dp">

        <ImageView
            android:id="@+id/ivBackButton"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true"
            android:src="@drawable/ic_arrow_back"
            android:padding="8dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Back" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Driver Registration"
            android:textStyle="bold"
            android:textSize="24sp"
            android:textColor="#333333"
            android:layout_centerInParent="true" />
    </RelativeLayout>

    <!-- ViewFlipper: each child = one step -->
    <ViewFlipper
        android:id="@+id/viewFlipper"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <!-- STEP 1: Personal Information -->
        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true"
            android:isScrollContainer="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp"
                android:paddingBottom="600dp"
                android:clipToPadding="false">

                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="24dp"
                    android:elevation="4dp"
                    app:cardCornerRadius="12dp"
                    app:cardBackgroundColor="#ffffff">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Personal Information"
                            android:textStyle="bold"
                            android:textSize="18sp"
                            android:textColor="#2c3e50"
                            android:layout_marginBottom="20dp" />

                        <com.google.android.material.textfield.TextInputLayout
                            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="16dp"
                            app:boxBackgroundMode="outline"
                            app:boxBackgroundColor="@android:color/white"
                            app:boxStrokeColor="#DDDDDD"
                            app:boxCornerRadiusTopStart="12dp"
                            app:boxCornerRadiusTopEnd="12dp"
                            app:boxCornerRadiusBottomStart="12dp"
                            app:boxCornerRadiusBottomEnd="12dp">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etFirstName"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:hint="First Name *"
                                android:textColor="#000000"
                                android:textColorHint="#CCCCCC"
                                android:inputType="textCapWords" />
                        </com.google.android.material.textfield.TextInputLayout>


                        <com.google.android.material.textfield.TextInputLayout
                            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="16dp"
                            app:boxBackgroundMode="outline"
                            app:boxBackgroundColor="@android:color/white"
                            app:boxStrokeColor="#DDDDDD"
                            app:boxCornerRadiusTopStart="12dp"
                            app:boxCornerRadiusTopEnd="12dp"
                            app:boxCornerRadiusBottomStart="12dp"
                            app:boxCornerRadiusBottomEnd="12dp">
                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etMiddleName"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:hint="Middle Name (Optional)"
                                android:inputType="textCapWords" />
                        </com.google.android.material.textfield.TextInputLayout>

                        <com.google.android.material.textfield.TextInputLayout
                            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="16dp"
                            app:boxBackgroundMode="outline"
                            app:boxBackgroundColor="@android:color/white"
                            app:boxStrokeColor="#DDDDDD"
                            app:boxCornerRadiusTopStart="12dp"
                            app:boxCornerRadiusTopEnd="12dp"
                            app:boxCornerRadiusBottomStart="12dp"
                            app:boxCornerRadiusBottomEnd="12dp">
                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etLastName"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:hint="Last Name *"
                                android:inputType="textCapWords" />
                        </com.google.android.material.textfield.TextInputLayout>

                        <com.google.android.material.textfield.TextInputLayout
                            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="16dp"
                            app:boxBackgroundMode="outline"
                            app:boxBackgroundColor="@android:color/white"
                            app:boxStrokeColor="#DDDDDD"
                            app:boxCornerRadiusTopStart="12dp"
                            app:boxCornerRadiusTopEnd="12dp"
                            app:boxCornerRadiusBottomStart="12dp"
                            app:boxCornerRadiusBottomEnd="12dp">
                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etEmailId"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:hint="Email *"
                                android:inputType="textEmailAddress" />
                        </com.google.android.material.textfield.TextInputLayout>

                        <com.google.android.material.textfield.TextInputLayout
                            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="16dp"
                            app:boxBackgroundMode="outline"
                            app:boxBackgroundColor="@android:color/white"
                            app:boxStrokeColor="#DDDDDD"
                            app:boxCornerRadiusTopStart="12dp"
                            app:boxCornerRadiusTopEnd="12dp"
                            app:boxCornerRadiusBottomStart="12dp"
                            app:boxCornerRadiusBottomEnd="12dp">
                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etPhoneNumber"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:hint="Phone Number *"
                                android:inputType="phone"
                                android:maxLength="10" />
                        </com.google.android.material.textfield.TextInputLayout>

                        <com.google.android.material.textfield.TextInputLayout
                            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="16dp"
                            app:boxBackgroundMode="outline"
                            app:boxBackgroundColor="@android:color/white"
                            app:boxStrokeColor="#DDDDDD"
                            app:boxCornerRadiusTopStart="12dp"
                            app:boxCornerRadiusTopEnd="12dp"
                            app:boxCornerRadiusBottomStart="12dp"
                            app:boxCornerRadiusBottomEnd="12dp">
                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etAadhar"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:hint="Aadhar Number *"
                                android:inputType="number"
                                android:maxLength="12" />
                        </com.google.android.material.textfield.TextInputLayout>

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Gender *"
                            android:textSize="14sp"
                            android:textColor="#555555"
                            android:layout_marginBottom="8dp" />

                        <RadioGroup
                            android:id="@+id/rgGender"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginBottom="16dp">

                            <RadioButton
                                android:id="@+id/rbMale"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Male" />

                            <RadioButton
                                android:id="@+id/rbFemale"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="Female" />
                        </RadioGroup>

                        <com.google.android.material.textfield.TextInputLayout
                            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="16dp"
                            app:boxBackgroundMode="outline"
                            app:boxBackgroundColor="@android:color/white"
                            app:boxStrokeColor="#DDDDDD"
                            app:boxCornerRadiusTopStart="12dp"
                            app:boxCornerRadiusTopEnd="12dp"
                            app:boxCornerRadiusBottomStart="12dp"
                            app:boxCornerRadiusBottomEnd="12dp"
                            app:passwordToggleEnabled="true">
                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etPassword"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:hint="Password *"
                                android:inputType="textPassword" />
                        </com.google.android.material.textfield.TextInputLayout>

                        <Button
                            android:id="@+id/btnNext1"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:backgroundTint="#E2AC0B"
                            app:boxCornerRadiusTopStart="12dp"
                            app:boxCornerRadiusTopEnd="12dp"
                            app:boxCornerRadiusBottomStart="12dp"
                            app:boxCornerRadiusBottomEnd="12dp"
                            android:text="Next →" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>
            </LinearLayout>
        </androidx.core.widget.NestedScrollView>

        <!-- STEP 2: Address Information -->
        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:elevation="4dp"
                    app:cardCornerRadius="12dp"
                    app:cardBackgroundColor="#ffffff">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Address Information"
                            android:textStyle="bold"
                            android:textSize="18sp"
                            android:textColor="#2c3e50"
                            android:layout_marginBottom="20dp" />

                        <com.google.android.material.textfield.TextInputLayout
                            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="16dp"
                            app:boxBackgroundMode="outline"
                            app:boxBackgroundColor="@android:color/white"
                            app:boxStrokeColor="#DDDDDD"
                            app:boxCornerRadiusTopStart="12dp"
                            app:boxCornerRadiusTopEnd="12dp"
                            app:boxCornerRadiusBottomStart="12dp"
                            app:boxCornerRadiusBottomEnd="12dp">
                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etAddress"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:hint="Street Address *"
                                android:inputType="textMultiLine"
                                android:minLines="2" />
                        </com.google.android.material.textfield.TextInputLayout>

                        <com.google.android.material.textfield.TextInputLayout
                            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="16dp"
                            app:boxBackgroundMode="outline"
                            app:boxBackgroundColor="@android:color/white"
                            app:boxStrokeColor="#DDDDDD"
                            app:boxCornerRadiusTopStart="12dp"
                            app:boxCornerRadiusTopEnd="12dp"
                            app:boxCornerRadiusBottomStart="12dp"
                            app:boxCornerRadiusBottomEnd="12dp">
                            <AutoCompleteTextView
                                android:id="@+id/actvState"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:hint="Select State *"
                                android:inputType="text"
                                android:focusable="true"
                                android:clickable="true"
                                android:completionThreshold="1" />

                        </com.google.android.material.textfield.TextInputLayout>

                        <com.google.android.material.textfield.TextInputLayout
                            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="16dp"
                            app:boxBackgroundMode="outline"
                            app:boxBackgroundColor="@android:color/white"
                            app:boxStrokeColor="#DDDDDD"
                            app:boxCornerRadiusTopStart="12dp"
                            app:boxCornerRadiusTopEnd="12dp"
                            app:boxCornerRadiusBottomStart="12dp"
                            app:boxCornerRadiusBottomEnd="12dp">
                            <AutoCompleteTextView
                                android:id="@+id/actvCity"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:hint="Select City *"
                                android:inputType="text"
                                android:focusable="true"
                                android:clickable="true"
                                android:completionThreshold="1" />
                        </com.google.android.material.textfield.TextInputLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                            <Button
                                android:id="@+id/btnBack2"
                                android:layout_width="0dp"
                                android:layout_weight="1"
                                android:layout_height="wrap_content"
                                android:layout_marginEnd="8dp"
                                android:backgroundTint="#E2AC0B"
                                android:text="← Back" />

                            <Button
                                android:id="@+id/btnNext2"
                                android:layout_width="0dp"
                                android:layout_weight="1"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="8dp"
                                android:backgroundTint="#E2AC0B"
                                android:text="Next →" />
                        </LinearLayout>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>
            </LinearLayout>
        </androidx.core.widget.NestedScrollView>

        <!-- STEP 3: Vehicle Information & Document Validity -->
        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:elevation="4dp"
                    app:cardCornerRadius="12dp"
                    app:cardBackgroundColor="#ffffff">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Vehicle Information"
                            android:textStyle="bold"
                            android:textSize="18sp"
                            android:textColor="#2c3e50"
                            android:layout_marginBottom="20dp" />

                        <com.google.android.material.textfield.TextInputLayout
                            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="16dp"
                            app:boxBackgroundMode="outline"
                            app:boxBackgroundColor="@android:color/white"
                            app:boxStrokeColor="#DDDDDD"
                            app:boxCornerRadiusTopStart="12dp"
                            app:boxCornerRadiusTopEnd="12dp"
                            app:boxCornerRadiusBottomStart="12dp"
                            app:boxCornerRadiusBottomEnd="12dp">
                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etVehicleNumber"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:hint="Vehicle Number *"
                                android:inputType="textCapCharacters" />
                        </com.google.android.material.textfield.TextInputLayout>

                        <com.google.android.material.textfield.TextInputLayout
                            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="16dp"
                            app:boxBackgroundMode="outline"
                            app:boxBackgroundColor="@android:color/white"
                            app:boxStrokeColor="#DDDDDD"
                            app:boxCornerRadiusTopStart="12dp"
                            app:boxCornerRadiusTopEnd="12dp"
                            app:boxCornerRadiusBottomStart="12dp"
                            app:boxCornerRadiusBottomEnd="12dp">
                            <AutoCompleteTextView
                                android:id="@+id/actvVehicleType"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:hint="Select Vehicle Type *"
                                android:inputType="text"
                                android:focusable="true"
                                android:clickable="true"
                                android:completionThreshold="1" />
                        </com.google.android.material.textfield.TextInputLayout>

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Document Validity"
                            android:textStyle="bold"
                            android:textSize="18sp"
                            android:textColor="#2c3e50"
                            android:layout_marginBottom="20dp" />

                        <com.google.android.material.textfield.TextInputLayout
                            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="16dp"
                            app:boxBackgroundMode="outline"
                            app:boxBackgroundColor="@android:color/white"
                            app:boxStrokeColor="#DDDDDD"
                            app:boxCornerRadiusTopStart="12dp"
                            app:boxCornerRadiusTopEnd="12dp"
                            app:boxCornerRadiusBottomStart="12dp"
                            app:boxCornerRadiusBottomEnd="12dp"
                            app:startIconDrawable="@android:drawable/ic_menu_my_calendar">
                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etDlValidTo"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:hint="Driving License Valid To *"
                                android:focusable="false"
                                android:clickable="true"
                                android:inputType="none" />
                        </com.google.android.material.textfield.TextInputLayout>

                        <com.google.android.material.textfield.TextInputLayout
                            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="16dp"
                            app:boxBackgroundMode="outline"
                            app:boxBackgroundColor="@android:color/white"
                            app:boxStrokeColor="#DDDDDD"
                            app:boxCornerRadiusTopStart="12dp"
                            app:boxCornerRadiusTopEnd="12dp"
                            app:boxCornerRadiusBottomStart="12dp"
                            app:boxCornerRadiusBottomEnd="12dp"
                            app:startIconDrawable="@android:drawable/ic_menu_my_calendar">
                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etInsuranceValidTo"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:hint="Insurance Valid To *"
                                android:focusable="false"
                                android:clickable="true"
                                android:inputType="none" />
                        </com.google.android.material.textfield.TextInputLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                            <Button
                                android:id="@+id/btnBack3"
                                android:layout_width="0dp"
                                android:layout_weight="1"
                                android:layout_height="wrap_content"
                                android:layout_marginEnd="8dp"
                                android:backgroundTint="#E2AC0B"
                                android:text="← Back" />

                            <Button
                                android:id="@+id/btnNext3"
                                android:layout_width="0dp"
                                android:layout_weight="1"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="8dp"
                                android:backgroundTint="#E2AC0B"
                                android:text="Next →" />
                        </LinearLayout>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>
            </LinearLayout>
        </ScrollView>

        <!-- STEP 4: Upload Documents -->
        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:elevation="4dp"
                    app:cardCornerRadius="12dp"
                    app:cardBackgroundColor="#ffffff">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Upload Documents"
                            android:textStyle="bold"
                            android:textSize="20sp"
                            android:textColor="#2c3e50"
                            android:layout_marginBottom="8dp" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Please upload all required documents"
                            android:textSize="14sp"
                            android:textColor="#7F8C8D"
                            android:layout_marginBottom="24dp" />

                        <!-- Dynamic Documents Container -->
                        <LinearLayout
                            android:id="@+id/documentsContainer"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:layout_marginBottom="24dp" />

                        <!-- Language Selection Section -->
                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Language Preferences"
                            android:textStyle="bold"
                            android:textSize="18sp"
                            android:textColor="#2c3e50"
                            android:layout_marginBottom="16dp" />

                        <com.google.android.material.textfield.TextInputLayout
                            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="16dp"
                            app:boxBackgroundMode="outline"
                            app:boxBackgroundColor="@android:color/white"
                            app:boxStrokeColor="#E2AC0B"
                            app:boxCornerRadiusTopStart="12dp"
                            app:boxCornerRadiusTopEnd="12dp"
                            app:boxCornerRadiusBottomStart="12dp"
                            app:boxCornerRadiusBottomEnd="12dp">

                            <AutoCompleteTextView
                                android:id="@+id/actvLanguage"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:hint="Select Language *"
                                android:inputType="text"
                                android:focusable="true"
                                android:clickable="true"
                                android:completionThreshold="1" />
                        </com.google.android.material.textfield.TextInputLayout>

                        <!-- Language Checkboxes -->
                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="16dp"
                            app:cardCornerRadius="8dp"
                            app:cardElevation="0dp"
                            app:strokeWidth="1dp"
                            app:strokeColor="#E0E0E0"
                            app:cardBackgroundColor="#F8F9FA">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="vertical"
                                android:padding="16dp">

                                <CheckBox
                                    android:id="@+id/etSpeak"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="I can speak English"
                                    android:textColor="#2C3E50"
                                    android:textSize="14sp"
                                    android:layout_marginBottom="8dp"
                                    android:buttonTint="#E2AC0B" />

                                <CheckBox
                                    android:id="@+id/etUnderstand"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="I can understand English"
                                    android:textColor="#2C3E50"
                                    android:textSize="14sp"
                                    android:buttonTint="#E2AC0B" />
                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>

                        <!-- Terms and Conditions -->
                        <com.google.android.material.card.MaterialCardView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="24dp"
                            app:cardCornerRadius="8dp"
                            app:cardElevation="0dp"
                            app:strokeWidth="1dp"
                            app:strokeColor="#E2AC0B"
                            app:cardBackgroundColor="#FFF9E6">

                            <CheckBox
                                android:id="@+id/etTermsConditions"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:padding="16dp"
                                android:text="I agree to the Terms and Conditions"
                                android:textColor="#2C3E50"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                android:buttonTint="#E2AC0B" />
                        </com.google.android.material.card.MaterialCardView>

                        <!-- Navigation Buttons -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:layout_marginBottom="16dp">

                            <Button
                                android:id="@+id/btnBack4"
                                android:layout_width="0dp"
                                android:layout_weight="1"
                                android:layout_height="56dp"
                                android:layout_marginEnd="8dp"
                                android:backgroundTint="#95A5A6"
                                android:text="← Back"
                                android:textSize="16sp"
                                app:cornerRadius="12dp" />

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnRegister"
                                android:layout_width="0dp"
                                android:layout_weight="2"
                                android:layout_height="56dp"
                                android:layout_marginStart="8dp"
                                android:text="Register as Driver"
                                android:textSize="16sp"
                                android:textStyle="bold"
                                app:cornerRadius="12dp"
                                app:backgroundTint="#27AE60"
                                app:icon="@drawable/ic_verification"
                                app:iconGravity="textEnd"
                                app:iconTint="#FFFFFF" />
                        </LinearLayout>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>
            </LinearLayout>
        </ScrollView>

    </ViewFlipper>
</LinearLayout>