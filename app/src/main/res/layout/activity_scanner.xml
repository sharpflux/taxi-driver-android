<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <!-- Camera Preview -->
    <androidx.camera.view.PreviewView
        android:id="@+id/previewView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:keepScreenOn="true"
        app:scaleType="fillCenter"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Top Bar -->
    <LinearLayout
        android:id="@+id/topBar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="20dp"
        android:paddingVertical="16dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Back Button -->
        <ImageButton
            android:id="@+id/btnBack"
            style="@style/ScannerButton"
            android:src="@drawable/ic_close"
            android:contentDescription="Back" />

        <View
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1" />

        <!-- Flash Button -->
        <ImageButton
            android:id="@+id/btnFlash"
            style="@style/ScannerButton"
            android:layout_marginEnd="12dp"
            android:src="@drawable/ic_flash_off"
            android:contentDescription="Flash" />

        <!-- QR Button -->
        <ImageButton
            android:id="@+id/btnQR"
            style="@style/ScannerButton"
            android:layout_marginEnd="12dp"
            android:src="@drawable/ic_scan"
            android:contentDescription="QR" />

        <!-- Menu Button -->
        <ImageButton
            android:id="@+id/btnMenu"
            style="@style/ScannerButton"
            android:src="@drawable/ic_more_vert"
            android:contentDescription="Menu" />

    </LinearLayout>

    <!-- Scanner Frame Container -->
    <FrameLayout
        android:id="@+id/scannerFrameContainer"
        android:layout_width="280dp"
        android:layout_height="280dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

<!--        &lt;!&ndash; Top Left Corner &ndash;&gt;-->
<!--        <View-->
<!--            android:layout_width="60dp"-->
<!--            android:layout_height="60dp"-->
<!--            android:layout_gravity="top|start"-->
<!--            android:background="@drawable/scanner_corner_top_left" />-->

<!--        &lt;!&ndash; Top Right Corner &ndash;&gt;-->
<!--        <View-->
<!--            android:layout_width="60dp"-->
<!--            android:layout_height="60dp"-->
<!--            android:layout_gravity="top|end"-->
<!--            android:background="@drawable/scanner_corner_top_right" />-->

<!--        &lt;!&ndash; Bottom Left Corner &ndash;&gt;-->
<!--        <View-->
<!--            android:layout_width="60dp"-->
<!--            android:layout_height="60dp"-->
<!--            android:layout_gravity="bottom|start"-->
<!--            android:background="@drawable/scanner_corner_bottom_left" />-->

<!--        &lt;!&ndash; Bottom Right Corner &ndash;&gt;-->
<!--        <View-->
<!--            android:layout_width="60dp"-->
<!--            android:layout_height="60dp"-->
<!--            android:layout_gravity="bottom|end"-->
<!--            android:background="@drawable/scanner_corner_bottom_right" />-->

        <!-- Center Blur Overlay (optional) -->
        <View
            android:id="@+id/centerOverlay"
            android:layout_width="160dp"
            android:layout_height="160dp"
            android:layout_gravity="center"
            android:background="@drawable/center_blur_overlay"
            android:alpha="0.3" />

    </FrameLayout>

    <!-- Upload from Gallery Button -->
    <LinearLayout
        android:id="@+id/btnUploadFromGallery"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        style="@style/UploadButtonStyle"
        android:gravity="center_vertical"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/scannerFrameContainer"
        android:layout_marginTop="60dp">

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_gallery"
            android:layout_marginEnd="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Upload from gallery"
            android:textColor="@color/scanner_upload_text"
            android:textSize="16sp"
            android:fontFamily="sans-serif" />

    </LinearLayout>

    <!-- Bottom Text -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="60dp">

        <!-- Divider Line -->
        <View
            android:layout_width="80dp"
            android:layout_height="2dp"
            android:background="#FFFFFF"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Scan any QR code to pay"
            style="@style/ScannerTextPrimary"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Google Pay • PhonePe • PayTM • UPI"
            style="@style/ScannerTextSecondary" />

        <!-- Bottom Indicator Line -->
        <View
            android:layout_width="60dp"
            android:layout_height="4dp"
            android:background="@drawable/bottom_indicator"
            android:layout_marginTop="20dp" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>