<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="?attr/surface_background_color">

    <!-- Header -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/terms_and_conditions"
        android:textStyle="bold"
        android:textSize="20sp"
        android:textColor="?attr/text_primary_color"
        android:layout_marginBottom="16dp"
        android:gravity="center" />

    <!-- Scrollable Content -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="300dp"
        android:layout_marginBottom="16dp"
        android:background="?attr/input_bg_color"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/terms_content"
                android:textSize="14sp"
                android:textColor="?attr/text_primary_color"
                android:lineSpacingExtra="4dp" />

        </LinearLayout>
    </ScrollView>

    <!-- Checkbox -->
    <CheckBox
        android:id="@+id/cbAgreeTerms"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/i_agree_terms"
        android:textColor="?attr/text_primary_color"
        android:textSize="14sp"
        android:textStyle="bold"
        android:buttonTint="@color/checkbox_tint"
        android:layout_marginBottom="16dp" />

    <!-- Buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

<!--        <Button-->
<!--            android:id="@+id/btnCancel"-->
<!--            android:layout_width="0dp"-->
<!--            android:layout_weight="1"-->
<!--            android:layout_height="wrap_content"-->
<!--            android:layout_marginEnd="8dp"-->
<!--            android:text="@string/cancel"-->
<!--            android:textColor="?attr/text_primary_color"-->
<!--            android:backgroundTint="?attr/text_secondary_color"-->
<!--            app:cornerRadius="12dp" />-->

        <Button
            android:id="@+id/btnAccept"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="@string/accept"
            android:textColor="@color/white"
            android:backgroundTint="@color/colorAccent"
            app:cornerRadius="12dp" />
    </LinearLayout>
</LinearLayout>